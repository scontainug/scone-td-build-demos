[226.688967, "o", "SCONE_SSPINS=100\r\nSCONE_SSLEEP=4000\r\nSCONE_CONFIG=/etc/sgx-musl.conf\r\nSCONE_TCS=8\r\nSCONE_LOG=WARNING\r\nSCONE_HEAP=2147483648\r\nSCONE_MIN_HEAP=8388608\r\nSCONE_STACK=2097152\r\nSCONE_ESPINS=10000\r\nSCONE_MODE=hw\r\nSCONE_EDMM_MODE=disable\r\nSCONE_ALLOW_DLOPEN=yes (unprotected)\r\nSCONE_MPROTECT=yes\r\nSCONE_FORK=no\r\nSCONE_FORK_OS=0\r\nSCONE_CONFIG_ID: slsfvvzfqz-session-scone-td-build/job-go-args-env-file/go-args-env-file-cas-default/go-args-env-file\r\n\r\nmusl version: 1.2.5\r\nSCONE version: 6.1.0-rc.0\r\nEnclave hash: 8bedecdd79467ccd05645fce182adceae3317153033fa069fa683e7bee0b3ae2\r\n[SCONE|WARN] src/enclave/dispatch.c:149:print_runtime_info(): Application runs in SGX debug mode. Its memory can be read from outside the enclave with a debugger! This is not secure!\r\n[SCONE|WARN] scone_rrt::implementation::eai rust-crates/scone_rrt/src/implementation/eai.rs:133:Insecure configuration that activates dynamic loading without singleton enclave!\r\n[SCONE|WARN] src/syscall/syscall.c:32:__scone_ni_syscall(): system call: membarrier, number 324 is not supported\r\n[SCONE|WARN] src/process/init.c:392:__scone_apply_secure_config(): Ignoring `SCONE_PWD` environment variable and host provided process working directory.\r\n"]
[226.689012, "o", "\tApplying process working directory from service's session configuration (/src)\r\n[SCONE|WARN] scone_rrt::implementation::state::secret_injection rust-crates/scone_rrt/src/implementation/state/secret_injection.rs:65:Ignoring secret injection file (template) content from /config/configs.yaml in the file system, since the file content is provided in the CAS session already.\r\n[SCONE|WARN] scone_rrt::implementation::state::secret_injection rust-crates/scone_rrt/src/implementation/state/secret_injection.rs:65:Ignoring secret injection file (template) content from /config/secrets in the file system, since the file content is provided in the CAS session already.\r\n[SCONE|WARN] src/shielding/fs_proc.c:825:proc_fs_open(): open: /proc/1/mountinfo is not supported/allowed\r\nGo-args-env-file V4\r\n\r\nCommand Line Arguments:\r\narg[0]: arg1\r\narg[1]: arg2\r\n\r\nEnvironment Variables:\r\n"]
[226.689214, "o", "SCONE_VERSION=1\r\nSCONE_LOG=\r\nAPP_ENV=production\r\nSCONE_LAS_ADDR=192.168.205.71\r\nPOD_NAME=\r\nPOD_NAMESPACE=\r\nSCONE_CONFIG_ID=slsfvvzfqz-session-scone-td-build/job-go-args-env-file/go-args-env-file-cas-default/go-args-env-file\r\n\r\nConfig File (/config/configs.yaml):\r\n"]
[226.689389, "o", "# Example configuration\r\napp:\r\n  name: go-args-env-file\r\n  log_level: info\r\nfeature_flags:\r\n  enable_debug: false\r\n\r\nSecrets File (/config/secrets):\r\nDB_PASSWORD=changeme\r\nAPI_KEY=replace-with-real-key\r\n\r\nSleeping for 10 seconds to keep the container alive...\r\nSleep completed.\r\nDone.\r\n"]
